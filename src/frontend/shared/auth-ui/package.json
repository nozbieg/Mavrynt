{
  "name": "@mavrynt/auth-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared authentication UI for Mavrynt SPAs — login/register forms, AuthService port, default console adapter, and bilingual (en/pl) i18n resources. Kept separate from @mavrynt/ui because it owns domain semantics (sessions, credentials, errors), while @mavrynt/ui stays purely presentational.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./forms": {
      "types": "./src/forms/index.ts",
      "import": "./src/forms/index.ts"
    },
    "./service": {
      "types": "./src/service/index.ts",
      "import": "./src/service/index.ts"
    },
    "./analytics": {
      "types": "./src/analytics/index.ts",
      "import": "./src/analytics/index.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "import": "./src/i18n/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.0.0"
  },
  "dependencies": {
    "@mavrynt/design-tokens": "*",
    "@mavrynt/ui": "*",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@mavrynt/tsconfig-base": "*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react-i18next": "^16.0.0",
    "typescript": "~6.0.2"
  }
}
