{
  "name": "@mavrynt/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared React UI primitives (Container, Section, Stack, Button, Link, Logo) plus layout (Navbar, Footer) and ThemeProvider for all Mavrynt SPAs.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.ts",
      "import": "./src/theme/index.ts"
    },
    "./layout": {
      "types": "./src/layout/index.ts",
      "import": "./src/layout/index.ts"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
      "import": "./src/primitives/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@mavrynt/design-tokens": "*",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@mavrynt/tsconfig-base": "*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "~6.0.2"
  }
}
