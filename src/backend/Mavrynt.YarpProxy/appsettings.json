{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "apiRoute": {
        "ClusterId": "api",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Order": 1
      },
      "adminApiRoute": {
        "ClusterId": "adminApi",
        "Match": {
          "Path": "/admin-api/{**catch-all}"
        },
        "Order": 2
      },
      "adminWebRoute": {
        "ClusterId": "adminWeb",
        "Match": {
          "Path": "/admin/{**catch-all}"
        },
        "Order": 3
      },
      "appRoute": {
        "ClusterId": "web",
        "Match": {
          "Path": "/app/{**catch-all}"
        },
        "Order": 4
      },
      "landingRoute": {
        "ClusterId": "landing",
        "Match": {
          "Path": "{**catch-all}"
        },
        "Order": 5
      }
    },
    "Clusters": {
      "api": {
        "Destinations": {
          "api": {
            "Address": "http://api"
          }
        }
      },
      "adminApi": {
        "Destinations": {
          "adminApi": {
            "Address": "http://adminApi"
          }
        }
      },
      "adminWeb": {
        "Destinations": {
          "adminWeb": {
            "Address": "http://adminWeb"
          }
        }
      },
      "web": {
        "Destinations": {
          "web": {
            "Address": "http://web"
          }
        }
      },
      "landing": {
        "Destinations": {
          "landing": {
            "Address": "http://landing"
          }
        }
      }
    }
  }
}

